# 1. Configuration IP (Passerelle : Le port 4 du FortiGate)
ifconfig eth0 192.168.126.226 netmask 255.255.255.240 up
route add default gw 192.168.126.225
echo "nameserver 8.8.8.8" > /etc/resolv.conf

# 2. Installation du serveur Web Apache
apt-get update
apt-get install apache2 -y

# 3. Démarrage du site Web
service apache2 start
service apache2 status
